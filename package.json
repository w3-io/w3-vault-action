{
  "name": "w3-vault-action",
  "version": "1.0.0",
  "private": true,
  "description": "W3 Vault Action — deposit and withdraw USDC from Yelay vaults with cross-chain CCTP",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "format": "prettier --write .",
    "lint": "eslint src/",
    "test": "node --test test/*.test.js",
    "all": "npm run format && npm run lint && npm run test && npm run build",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@w3-io/action-core": "^0.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0"
  }
}
